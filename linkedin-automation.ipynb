#' Assemble the full post text
format_post_text <- function(post) {
      paste0(post$hook, "\n\n", post$body, post$cta, "\n\n", post$hashtags)
  # paste0(post$body, post$cta, "\n\n", post$hashtags)
}

#' Post to LinkedIn (text + optional image asset URN)
post_to_linkedin <- function(text, person_urn, access_token, image_asset = NULL) {
  url <- "https://api.linkedin.com/v2/ugcPosts"

  share_content <- list(
    shareCommentary    = list(text = text),
    shareMediaCategory = if (is.null(image_asset)) "NONE" else "IMAGE"
  )
  if (!is.null(image_asset)) {
    share_content$media <- list(
      list(
        status          = "READY",
        description     = list(text = ""),
        media           = image_asset,
        title           = list(text = "")
      )
    )
  }

  payload <- list(
    author         = person_urn,
    lifecycleState = "PUBLISHED",
    specificContent = list(
      `com.linkedin.ugc.ShareContent` = share_content
    ),
    visibility = list(
      `com.linkedin.ugc.MemberNetworkVisibility` = "PUBLIC"
    )
  )

  resp <- request(url) |>
    req_auth_bearer_token(access_token) |>
    req_headers("X-Restli-Protocol-Version" = "2.0.0") |>
    req_body_json(payload) |>
    req_perform()

  if (resp_status(resp) == 201) {
    post_id <- resp_body_json(resp)$id
    return(list(success = TRUE, post_id = post_id))
  } else {
    return(list(
      success      = FALSE,
      post_id      = NA,
      status_code  = resp_status(resp),
      error        = resp_body_string(resp)
    ))
  }
}


