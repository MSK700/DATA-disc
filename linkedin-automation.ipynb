#  LOGGING
# ══════════════════════════════════════════════════════════════════

save_log <- function(entry) {
  log <- list()
  if (file.exists(LOG_FILE)) {
    log <- tryCatch(fromJSON(LOG_FILE, simplifyVector = FALSE), error = function(e) list())
  }
  log <- c(log, list(entry))
  write(toJSON(log, auto_unbox = TRUE, pretty = TRUE), LOG_FILE)
}


