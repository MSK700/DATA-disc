#' Determine today's post index
get_today_post <- function(start_date = CAMPAIGN_START) {
  delta <- as.integer(Sys.Date() - start_date)
  idx   <- delta + 1L
  if (idx < 1L) { message("Campaign hasn't started yet."); return(NULL) }
  if (idx > length(POSTS)) { message("All 20 posts complete!"); return(NULL) }
  POSTS[[idx]]
}

#' Preview a post without publishing
preview_post <- function(day_number) {
  post <- POSTS[[day_number]]
  text <- format_post_text(post)
  cat(rep("=", 60), "\n", sep = "")
  cat(sprintf("DAY %d; %s\n", post$day, toupper(post$type)))
  cat(sprintf("IMAGE QUERY: %s\n", post$image_q))
  cat(rep("=", 60), "\n\n", sep = "")
  cat(text, "\n\n")
  cat(sprintf("[%d / %d chars]\n", nchar(text), CHAR_LIMIT))
  if (nchar(text) > CHAR_LIMIT) cat("⚠️  OVER LIMIT; shorten the body!\n")
}

#' Preview all posts with char count check
preview_all <- function() {
  for (i in seq_along(POSTS)) {
    p     <- POSTS[[i]]
    text  <- format_post_text(p)
    chars <- nchar(text)
    flag  <- if (chars > CHAR_LIMIT) "⚠️ OVER" else "✅ OK"
    cat(sprintf("Day %2d | %-35s | %4d chars | %s\n", i, p$type, chars, flag))
  }
}

#' Post a specific day manually
post_day <- function(day_number, with_image = TRUE) {
  if (nchar(ACCESS_TOKEN) == 0) stop("LINKEDIN_ACCESS_TOKEN not set.")
  if (nchar(PERSON_URN) == 0)   stop("LINKEDIN_PERSON_URN not set.")

  post      <- POSTS[[day_number]]
  post_text <- format_post_text(post)
  char_n    <- nchar(post_text)

  message(sprintf("📝 Day %d: %s (%d chars)", post$day, post$type, char_n))
  if (char_n > CHAR_LIMIT) stop("Post exceeds LinkedIn limit. Shorten the body.")

  # Upload image
  image_asset <- NULL
  if (with_image) {
    image_asset <- tryCatch(
      prepare_post_image(post$image_q, ACCESS_TOKEN, PERSON_URN),
      error = function(e) { message("Image skipped: ", e$message); NULL }
    )
  }

  # Post
  result <- post_to_linkedin(post_text, PERSON_URN, ACCESS_TOKEN, image_asset)

  # Log
  log_entry <- list(
    timestamp   = as.character(Sys.time()),
    day         = post$day,
    type        = post$type,
    hook        = substr(post$hook, 1, 80),
    chars       = char_n,
    has_image   = !is.null(image_asset),
    image_query = post$image_q,
    success     = result$success,
    post_id     = result$post_id
  )
  save_log(log_entry)

  # Slack
  if (result$success) {
    msg <- sprintf(
      "✅ *LinkedIn Post Published*\n*Day %d/20*; %s\n*Hook:* %s\n*Post ID:* `%s`\n*Image:* %s\n*Chars:* %d/3000",
      post$day, post$type, substr(post$hook, 1, 60),
      result$post_id, if(!is.null(image_asset)) "✅ uploaded" else "❌ skipped",
      char_n
    )
    message("✅ Published! Post ID: ", result$post_id)
  } else {
    msg <- sprintf(
      "❌ *LinkedIn Post FAILED*\n*Day %d*; %s\n*Error:* %s",
      post$day, post$type, result$error %||% "unknown"
    )
    message("❌ Failed: ", result$error)
  }
  invisible(result)
}

# Null coalescing helper
`%||%` <- function(a, b) if (!is.null(a) && !is.na(a) && nchar(a) > 0) a else b


# ══════════════════════════════════════════════════════════════════
#  MAIN; runs automatically on Kaggle schedule
# ══════════════════════════════════════════════════════════════════

main <- function() {
  cat(sprintf("🕐 %s UTC\n", format(Sys.time(), tz = "UTC")))
  cat(sprintf("📅 Campaign start: %s\n", CAMPAIGN_START))

  post <- get_today_post()
  if (is.null(post)) {
    return(invisible(NULL))
  }

  cat(sprintf("\n🚀 Posting Day %d: %s\n", post$day, post$hook))
  post_day(post$day, with_image = TRUE)
}

