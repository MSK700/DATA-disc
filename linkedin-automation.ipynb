#  LINKEDIN IMAGE UPLOAD (2-step process required by API v2)
# ══════════════════════════════════════════════════════════════════

#' Search Unsplash for a relevant image and return its binary data
#' Unsplash Source API; free, no auth needed
fetch_image_bytes <- function(query, width = 1200, height = 628) {
  url <- sprintf(
    "https://source.unsplash.com/featured/%dx%d/?%s",
    width, height,
    utils::URLencode(query, reserved = TRUE)
  )
  tryCatch({
    resp <- request(url) |>
      req_options(followlocation = TRUE, timeout = 30) |>
      req_perform()
    if (resp_status(resp) == 200) {
      return(resp_body_raw(resp))
    }
    NULL
  }, error = function(e) { message("Image fetch failed: ", e$message); NULL })
}

#' Step 1: Register image asset with LinkedIn and get upload URL
register_linkedin_image <- function(access_token, person_urn) {
  url <- "https://api.linkedin.com/v2/assets?action=registerUpload"
  payload <- list(
    registerUploadRequest = list(
      recipes    = list("urn:li:digitalmediaRecipe:feedshare-image"),
      owner      = person_urn,
      serviceRelationships = list(
        list(
          relationshipType = "OWNER",
          identifier       = "urn:li:userGeneratedContent"
        )
      )
    )
  )
  resp <- request(url) |>
    req_auth_bearer_token(access_token) |>
    req_headers("X-Restli-Protocol-Version" = "2.0.0") |>
    req_body_json(payload) |>
    req_perform()
  if (resp_status(resp) == 200) {
    body       <- resp_body_json(resp)
    upload_url <- body$value$uploadMechanism$`com.linkedin.digitalmedia.uploading.MediaUploadHttpRequest`$uploadUrl
    asset      <- body$value$asset
    return(list(upload_url = upload_url, asset = asset))
  }
  NULL
}

#' Step 2: Upload image bytes to LinkedIn's upload URL
upload_image_to_linkedin <- function(upload_url, image_bytes) {
  resp <- request(upload_url) |>
    req_method("PUT") |>
    req_headers("Content-Type" = "image/jpeg") |>
    req_body_raw(image_bytes, type = "image/jpeg") |>
    req_perform()
  resp_status(resp) %in% c(200, 201)
}

#' Full image pipeline: fetch → register → upload → return asset URN
prepare_post_image <- function(query, access_token, person_urn) {
  message("  📷 Fetching image for: '", query, "'")
  img_bytes <- fetch_image_bytes(query)
  if (is.null(img_bytes)) return(NULL)

  message("  📤 Registering image with LinkedIn...")
  reg <- register_linkedin_image(access_token, person_urn)
  if (is.null(reg)) return(NULL)

  message("  ⬆️  Uploading image...")
  success <- upload_image_to_linkedin(reg$upload_url, img_bytes)
  if (!success) return(NULL)

  message("  ✅ Image ready: ", reg$asset)
  reg$asset
}


