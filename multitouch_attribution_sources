-- select
-- *,
-- coalesce(utm_source,session_source) session_source,
-- coalesce(utm_medium,session_medium) session_medium,
-- coalesce(utm_campaign,session_campaign) session_campaign
-- from cte

,co as(SELECT 
  *EXCEPT(session_source, session_medium, session_campaign),
  COALESCE(utm_source, session_source) AS session_source,
  COALESCE(utm_medium, session_medium) AS session_medium,
  COALESCE(utm_campaign, session_campaign) AS session_campaign
FROM cte)

select
*,
CASE 
    WHEN LOWER(session_medium) = 'referral' THEN 'Referral'
    WHEN LOWER(session_source) = '(direct)' AND (LOWER(session_medium) IN ('(not set)','(none)')) THEN 'Direct'
    WHEN REGEXP_CONTAINS(LOWER(session_campaign), 'cross-network') THEN 'Cross-network'
    
    WHEN (REGEXP_CONTAINS(LOWER(session_source),'alibaba|amazon|google shopping|shopify|etsy|ebay|stripe|walmart')
      OR REGEXP_CONTAINS(LOWER(session_campaign), '^(.*(([^a-df-z]|^)shop|shopping).*)$'))
      AND REGEXP_CONTAINS(LOWER(session_medium), '^(.*cp.*|ppc|paid.*)$') THEN 'Paid Shopping'
    
    WHEN REGEXP_CONTAINS(LOWER(session_source),'baidu|bing|duckduckgo|ecosia|google|yahoo|yandex')
      AND REGEXP_CONTAINS(LOWER(session_medium),'^(.*cp.*|ppc|paid.*)$') THEN 'Paid Search'
    
    WHEN REGEXP_CONTAINS(LOWER(session_source),'social_ads_|social_|badoo|facebook|fb|instagram|linkedin|pinterest|tiktok|twitter|whatsapp|social|ads')
      AND REGEXP_CONTAINS(LOWER(session_medium),'^(.*cp.*|ppc|facebook|paid.*)$') THEN 'Paid Social'
    
    WHEN REGEXP_CONTAINS(LOWER(session_source),'dailymotion|disneyplus|netflix|youtube|vimeo|twitch|vimeo|youtube')
      AND REGEXP_CONTAINS(LOWER(session_medium),'^(.*cp.*|ppc|paid.*)$') THEN 'Paid Video'
    
    WHEN LOWER(session_medium) IN ('display', 'banner', 'expandable', 'interstitial', 'cpm') THEN 'Display'
    
    WHEN REGEXP_CONTAINS(LOWER(session_source),'alibaba|amazon|google shopping|shopify|etsy|ebay|stripe|walmart')
      OR REGEXP_CONTAINS(LOWER(session_campaign), '^(.*(([^a-df-z]|^)shop|shopping).*)$') THEN 'Organic Shopping'
    
    WHEN REGEXP_CONTAINS(LOWER(session_source),'badoo|facebook|fb|instagram|linkedin|pinterest|tiktok|twitter|whatsapp|social')
      OR LOWER(session_medium) IN ('social','social-network','social-media','sm','social network','social media','facebook') THEN 'Organic Social'
    
    WHEN REGEXP_CONTAINS(LOWER(session_source),'dailymotion|disneyplus|netflix|youtube|vimeo|twitch|vimeo|youtube')
      OR REGEXP_CONTAINS(LOWER(session_medium),'^(.*video.*)$') THEN 'Organic Video'
    
    WHEN REGEXP_CONTAINS(LOWER(session_source),'baidu|bing|duckduckgo|ecosia|google|yahoo|yandex')
      OR LOWER(session_medium) = 'organic' THEN 'Organic Search'
    
    WHEN REGEXP_CONTAINS(LOWER(session_source),'email|e-mail|e_mail|e mail|Emailer|emailer|mail')
      OR REGEXP_CONTAINS(LOWER(session_medium),'email|e-mail|e_mail|e mail') THEN 'Email'
    
    WHEN LOWER(session_medium) = 'affiliate' THEN 'Affiliates'
    
    WHEN LOWER(session_medium) = 'audio' THEN 'Audio'
    WHEN LOWER(session_source) LIKE '%sms%' THEN 'SMS'
    WHEN LOWER(session_medium) LIKE '%push'
      OR REGEXP_CONTAINS(LOWER(session_medium),'mobile|notification') THEN 'Mobile Push Notifications'
    
    ELSE default_channel_group 
  END AS channel_grouping_user
  from co
