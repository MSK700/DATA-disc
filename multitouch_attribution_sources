,cte as(SELECT
distinct
  brand,revenue,
  -- _table_suffix,
  TIMESTAMP_MICROS(user_first_touch_timestamp) frst_touct_time,
  -- dataset_storage,
  -- ads_storage,
  event_date,event_name,
  TIMESTAMP_MICROS(event_timestamp) time_,
  user_pseudo_id,
  first_value(user_id ignore nulls)over(partition by user_pseudo_id order by user_first_touch_timestamp)user_id,
  (SELECT value.int_value FROM UNNEST(event_params) WHERE key = 'ga_session_id') AS session_id,
  CONCAT(user_pseudo_id) AS property_client_id,
  (SELECT value.string_value  FROM   UNNEST(event_params)    WHERE  KEY = 'page_location') page_location,
  REGEXP_EXTRACT((SELECT value.string_value  FROM   UNNEST(event_params)    WHERE  KEY = 'page_location'), r'fbclid=([^&]*)') AS fbclid,
  REGEXP_EXTRACT((SELECT value.string_value  FROM   UNNEST(event_params)    WHERE  KEY = 'page_location'), r'gclid=([^&]*)') AS gclid,
  REGEXP_EXTRACT((SELECT value.string_value  FROM   UNNEST(event_params)    WHERE  KEY = 'page_location'), r'msclkid=([^&]*)') AS msclkid,
  first_value(REGEXP_EXTRACT((SELECT value.string_value FROM UNNEST(event_params) WHERE key = 'page_location'), r'utm_source=([^&]*)') ignore nulls)over(partition by user_pseudo_id,(SELECT value.int_value FROM UNNEST(event_params) WHERE key = 'ga_session_id') order by user_first_touch_timestamp) AS utm_source,
  first_value(REGEXP_EXTRACT((SELECT value.string_value FROM UNNEST(event_params) WHERE key = 'page_location'), r'utm_medium=([^&]*)') ignore nulls)over(partition by user_pseudo_id,(SELECT value.int_value FROM UNNEST(event_params) WHERE key = 'ga_session_id') order by user_first_touch_timestamp) AS utm_medium,
  first_value(REGEXP_EXTRACT((SELECT value.string_value FROM UNNEST(event_params) WHERE key = 'page_location'), r'utm_campaign=([^&]*)') ignore nulls)over(partition by user_pseudo_id,(SELECT value.int_value FROM UNNEST(event_params) WHERE key = 'ga_session_id') order by user_first_touch_timestamp) AS utm_campaign,
  traffic_source.name AS _user_campaign_name,
  traffic_source.medium AS user_medium,
  traffic_source.source AS user_source,
  session_campaign,
  session_source,
  session_medium,
  default_channel_group
FROM
  cte_base
