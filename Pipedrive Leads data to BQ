names(leads_archived) <- ifelse(names(leads_archived) %in% names(col_map), col_map[names(leads_archived)], names(leads_archived))

# List columns (label_ids) ko string mein convert karein taake join mein error na aaye
fix_lists <- function(df) {
  df$label_ids <- sapply(df$label_ids, function(x) paste(x, collapse = ","))
  if ("value" %in% names(df)) {
    df$value_amount <- df$value$amount
    df$value_currency <- df$value$currency
    df$value <- NULL
  }
  return(df)
}
leads_active <- fix_lists(leads_active)
leads_archived <- fix_lists(leads_archived)

# RBINDING: Sirf wo columns choose karein jo Active leads mein hain (intersection)
common_cols <- intersect(names(leads_active), names(leads_archived))
leads_final <- bind_rows(leads_active[, common_cols], leads_archived[, common_cols])

