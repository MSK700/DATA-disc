# 1. GET ALL ACTIVE LEADS
# Active leads ka data fetch karne ke liye loop
base_url_active <- paste0("https://", company_domain, ".pipedrive.com/v1/leads")
all_active <- list()
start <- 0

repeat {
  res <- GET(base_url_active, query = list(api_token = api_token, start = start, limit = 500))
  data <- fromJSON(content(res, "text", encoding = "UTF-8"))
  if (length(data$data) > 0) all_active <- c(all_active, list(data$data))
  if (is.null(data$additional_data$pagination$more_items_in_collection) || !data$additional_data$pagination$more_items_in_collection) break
  start <- data$additional_data$pagination$next_start
}
leads_active <- bind_rows(all_active)
leads_active$lead_status <- "active"

# 2. GET ALL ARCHIVED LEADS
# Archived leads ka data alag endpoint se nikalte hain
base_url_archived <- paste0("https://", company_domain, ".pipedrive.com/v1/leads/archived")
all_archived <- list()
start <- 0

repeat {
  res <- GET(base_url_archived, query = list(api_token = api_token, start = start, limit = 500))
  data <- fromJSON(content(res, "text", encoding = "UTF-8"))
  if (length(data$data) > 0) all_archived <- c(all_archived, list(data$data))
  if (is.null(data$additional_data$pagination$more_items_in_collection) || !data$additional_data$pagination$more_items_in_collection) break
  start <- data$additional_data$pagination$next_start
}
leads_archived <- bind_rows(all_archived)
leads_archived$lead_status <- "archived"

# 3. RENAMING, LIST FIXING, AND RBINDING
# Pehle column renaming karlete hain dono datasets par
